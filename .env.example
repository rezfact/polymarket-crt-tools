# =============================================================================
# Copy to `.env` in the repo root. Loaded by `load_dotenv_files()` (shell exports
# win over `.env`). See each section below.
# =============================================================================

# -----------------------------------------------------------------------------
# Step 1 — Telegram + healthcheck (`scripts/healthcheck_telegram.py`, future live)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_MESSAGE_THREAD_ID=   # optional: supergroup forum topic id

# -----------------------------------------------------------------------------
# Step 2 — Sizing (default in code is max $10/slice; optional env for your worker)
# -----------------------------------------------------------------------------
# LIVE_MAX_STAKE_USD=10   # not read by `trade_usd_from_capital` yet — pass max_stake_usd in code or extend worker

# -----------------------------------------------------------------------------
# Step 3 — Redeem scheduler (`scripts/redeem_hourly.py`, `scripts/redeem_wins.py`)
# -----------------------------------------------------------------------------
POLYGON_PRIVATE_KEY=
# POLYMARKET_PRIVATE_KEY=   # optional alias; redeem accepts either
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# -----------------------------------------------------------------------------
# Polymarket trading / CLOB + builder (py-clob-client / WS live worker — keys below are
# documented for `.env`; this repo does not read POLY_BUILDER_* until you wire the client.)
# -----------------------------------------------------------------------------
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=
# POLYMARKET_SIGNATURE_TYPE=0
# 0=EOA, 1=proxy/Magic-link style, 2=browser wallet — must match your Polymarket account + py-clob-client

POLYMARKET_GAMMA_EVENT_SLUG_URL=https://gamma-api.polymarket.com/events/slug
# Override if Gamma base changes (also used by `polymarket_htf.config_env`)
# Read-only Polymarket check (Data API /positions for funder or signer — not full CLOB auth):
#   python scripts/validate_env.py --polymarket-positions

# -----------------------------------------------------------------------------
# Month CRT batch (`scripts/month_crt_wss.py`) — prefix CRT_MONTH_
# -----------------------------------------------------------------------------
CRT_MONTH_START=2026-01-10
CRT_MONTH_END=2026-04-01
CRT_MONTH_ASSET=btc
CRT_MONTH_PRICE_SOURCE=pyth
CRT_MONTH_WSS_SPOT_SOURCE=crt_15m
CRT_MONTH_CRT_PRESET=loose
CRT_MONTH_WSS_PRESET=coarse_spot
CRT_MONTH_CRT_BARS_OUT=var/crt_bars.jsonl
CRT_MONTH_WSS_OUT=var/wss_sim.jsonl
CRT_MONTH_TOY_STAKE_USD=1
CRT_MONTH_TOY_YES_MID=0.5
CRT_MONTH_TOY_FEE_ROUNDTRIP_BPS=0
CRT_MONTH_SKIP_WSS=0
CRT_MONTH_FETCH_GAMMA=0
CRT_MONTH_SPOT_VISION=0
CRT_MONTH_CRT_NO_HTF_FILTER=0
CRT_MONTH_INSECURE_TLS=0

# CRT_MONTH_WARMUP_DAYS=45
# CRT_MONTH_PULLBACK_FRAC=0.0008
# CRT_MONTH_FIB_LO=0.618
# CRT_MONTH_FIB_HI=0.786
# CRT_MONTH_ENTRY_END_BUFFER_SEC=90
# CRT_MONTH_ENTRY_FIRST_MINUTES=8
# CRT_MONTH_SLUG_OFFSET_STEPS=1
# CRT_MONTH_ENTRY_MODE=until_buffer
# CRT_MONTH_MAX_GAMMA_OUTCOME_DEV=0.12
# CRT_MONTH_RANGE_LOOKBACK=24
# CRT_MONTH_EXEC_INTERVAL=15m
# CRT_MONTH_CONTEXT_INTERVAL=1h
# CRT_MONTH_CRT_SWEEP_CONFLICT=skip

# -----------------------------------------------------------------------------
# Pyth chart OHLC (`--price-source pyth` → Benchmarks TradingView history)
# -----------------------------------------------------------------------------
# Optional: attach auth for your Pyth / Benchmarks API key (higher limits if your plan supports it).
# PYTH_API_KEY=
# PYTH_BENCHMARKS_API_KEY=   # alias of PYTH_API_KEY
# PYTH_API_AUTH_SCHEME=Bearer   # or Token, etc.; use "raw" to send the key as the full Authorization value
# PYTH_API_KEY_HEADER=X-Api-Key   # if set, key is sent in this header instead of Authorization
# PYTH_BENCHMARKS_TV_HISTORY_URL=https://benchmarks.pyth.network/v1/shims/tradingview/history

# -----------------------------------------------------------------------------
# Take-profit ladder (`scripts/watch_take_profit.py`) — planning only until CLOB sells wired
# -----------------------------------------------------------------------------
# Premium return = (curPrice - avgPrice) / avgPrice * 100. Example: sell half of remaining at +500%,
# then sell all remaining at +1000% (comma-separated threshold_pct:fraction_of_remaining).
# TAKE_PROFIT_TIERS=500:0.5,1000:1
# Same SPEC in CRT backtest: ``python scripts/backtest.py ... --tp-tiers "500:0.5,1000:1"`` (linear bridge to toy 0/1).

# -----------------------------------------------------------------------------
# Misc (venv re-exec, TLS)
# -----------------------------------------------------------------------------
# POLYMARKET_HTF_PYTHON=/path/to/.venv313/bin/python
# POLYMARKET_HTF_NO_VENV_REEXEC=1
# REQUESTS_VERIFY=0
# SSL_CERT_FILE=   # e.g. output of `python -c "import certifi; print(certifi.where())"`
